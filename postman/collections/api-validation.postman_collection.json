              "",
              "pm.test(\"Confirm deleted task parameters\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.task.title).to.eql(\"API Newman Verification Task\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
