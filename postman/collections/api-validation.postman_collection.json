{
  "info": {
    "_postman_id": "8c59f20e-c2f8-47bc-ad74-325dbcd35a82",
    "name": "SUT API Validation Suite",
    "description": "API verification collection for the AI-Augmented QA Demo SUT. Validates Authentication, Profile retrieval, and Task Board CRUD workflows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Verify token structure in body\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.token).to.not.be.undefined;",
              "    pm.expect(jsonData.token).to.include(\"mock-token\");",
              "    ",
              "    // Set environment variable for future requests",
              "    pm.environment.set(\"jwt_token\", jsonData.token);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
