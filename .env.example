# =========================================================================
# AI-QA Copilot Environment Variables Configuration
# Copy this file to a new file named '.env' and populate the variables:
# cp .env.example .env
# =========================================================================

# [LLM Copilot Configuration]
# 1. Your Gemini Developer API Key (generated in Google AI Studio)
# GEMINI_API_KEY=AIzaSy...your_gemini_token...

# 2. Select the Gemini model to use (Defaults to gemini-2.5-flash)
# Options: gemini-2.5-flash, gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# 3. Simulated delay in milliseconds for the Mock Copilot fallback generator
MOCK_DELAY_MS=800


# [Application & Server Configuration]
# 4. Port where the Express backend SUT app will listen
PORT=3000


# [Test Automation Configuration]
# 5. API endpoint target for Postman/Newman tests (Defaults to http://localhost:3000)
NEWMAN_BASE_URL=http://localhost:3000

# 6. Cypress UI E2E test target (Cypress automatically parses variables prefixed with CYPRESS_)
CYPRESS_baseUrl=http://localhost:3000
