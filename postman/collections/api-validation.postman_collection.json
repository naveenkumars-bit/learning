    {
      "name": "Tasks - Create Task Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Verify task created properties\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.task.title).to.eql(\"API Newman Verification Task\");",
              "    pm.expect(jsonData.task.status).to.eql(\"todo\");",
              "    ",
              "    // Capture created task ID for cleanup deletion test",
              "    pm.environment.set(\"newman_task_id\", jsonData.task.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"API Newman Verification Task\",\n  \"description\": \"Verify CRUD endpoints from Newman integration script\",\n  \"status\": \"todo\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tasks",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
