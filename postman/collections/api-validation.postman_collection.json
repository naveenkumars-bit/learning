              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Verify default profile structure\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.profile.username).to.eql(\"QA_Engineer\");",
              "    pm.expect(jsonData.profile.email).to.eql(\"qa@company.com\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
